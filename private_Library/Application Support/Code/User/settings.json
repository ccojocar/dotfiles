{
    "breadcrumbs.enabled": false,
    "C_Cpp.autocomplete": "disabled",
    "C_Cpp.errorSquiggles": "disabled",
    "C_Cpp.formatting": "disabled",
    "C_Cpp.intelliSenseEngine": "disabled",
    "checkpatch.checkpatchPath": "scripts/checkpatch.pl",
    "checkpatch.exclude": [
        "**/.vscode/autostart/*.c"
    ],
    "checkpatch.run": "onSave",
    "debug.allowBreakpointsEverywhere": true,
    "debug.onTaskErrors": "debugAnyway",
    "diffEditor.renderSideBySide": false,
    "editor.minimap.enabled": false,
    "editor.fontFamily": "Source Code Pro for Powerline",
    "editor.lineNumbers": "on",
    "editor.codeLens": false,
    "editor.suggestSelection": "first",
    "editor.letterSpacing": 0.40,
    "editor.lineHeight": 18,
    "editor.links": false,
    "editor.fontSize": 13,
    "editor.inlayHints.enabled": "offUnlessPressed",
    "extensions.ignoreRecommendations": true,
    "files.associations": {
        "**/Kokonut.config": "textproto",
        "**/arch/x86/entry/calling.h": "asm-intel-x86-generic",
        "**/arm64/**/*.S": "arm64",
        "**/x86/**/*.S": "asm-intel-x86-generic",
        "*_defconfig": "kconfig"
    },
    "files.exclude": {
        "**/*.a": true,
        "**/*.builtin": true,
        "**/*.map": true,
        "**/*.modinfo": true,
        "**/*.o": true,
        "**/*.order": true,
        "**/*.orig": true,
        "**/*.symvers": true,
        "**/*.tmp": true,
        "**/.*.S": true,
        "**/.*.cmd": true,
        "**/.*.d": true,
        "**/.tmp*": true,
        "*.cache/**": true
    },
    "files.trimFinalNewlines": true,
    "go.useLanguageServer": true,
    "go.goplsOptions": {
        "build.gopackagesDriver": "google3/devtools/gopackages",
    },
    "go.alternateTools": {
        "go-langserver": "gopls"
    },
    "go.vetOnSave": "off",
    "go.testTimeout": "5m",
    "[go]": {
        "editor.snippetSuggestions": "none",
        "editor.formatOnSave": true,
        "editor.codeActionsOnSave": {
            "source.organizeImports": "explicit"
        }
    },
    "git.enableCommitSigning": true,
    "git.openRepositoryInParentFolders": "always",
    "git.alwaysSignOff": true,
    "search.exclude": {
        "**/*.a": true,
        "**/*.builtin": true,
        "**/*.map": true,
        "**/*.modinfo": true,
        "**/*.o": true,
        "**/*.order": true,
        "**/*.orig": true,
        "**/*.symvers": true,
        "**/*.tmp": true,
        "**/.*.S": true,
        "**/.*.cmd": true,
        "**/.*.d": true,
        "**/.tmp*": true,
        "*.cache/**": true
    },
    "security.workspace.trust.untrustedFiles": "open",
    "systemtap-assistant.deploy-task": "Build systemtap tracer",
    "systemtap-assistant.output": ".vscode/autostart/tracer.stp",
    "trailing-spaces.deleteModifiedLinesOnly": true,
    "trailing-spaces.highlightCurrentLine": false,
    "trailing-spaces.trimOnSave": true,
    "redhat.telemetry.enabled": false,
    "workbench.colorCustomizations": {
        "statusBar.background": "#363537",
        "statusBar.noFolderBackground": "#363537",
        "statusBar.debuggingBackground": "#363537",
        "statusBar.foreground": "#ffffff",
        "statusBar.debuggingForeground": "#ffffff"
    },
    "workbench.startupEditor": "none",
    "vim.easymotion": true,
    "vim.sneak": true,
    "vim.incsearch": true,
    "vim.useSystemClipboard": true,
    "vim.useCtrlKeys": true,
    "vim.hlsearch": true,
    "vim.leader": "<space>",
    "vim.handleKeys": {
        "<C-d>": true,
        "<C-a>": false,
        "<C-f>": false
    },
    "extensions.experimental.affinity": {
        "vscode.vim": 1
    },
    "vim.insertModeKeyBindings": [
        {
            "before": [
                "j",
                "j"
