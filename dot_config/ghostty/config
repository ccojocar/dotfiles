# Appearance
theme = Monokai Pro
font-family = "Source Code Pro for Powerline"
font-size = 12
cursor-style = block

# Shell
shell-integration = zsh

# Behavior
# This command launches tmux automatically on startup
command = /bin/zsh -c "tmux attach -t init || tmux new -s init"

# Window Settings
window-decoration = true
window-padding-x = 10
window-padding-y = 10
